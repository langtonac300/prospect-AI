<script>
    // ============================================
    // AUDIENCE DETECTION & PERSONALIZATION
    // ============================================
    function detectAudience() {
        // Get referrer and UTM params
        const referrer = document.referrer;
        const urlParams = new URLSearchParams(window.location.search);
        const utm_source = urlParams.get('utm_source') || '';
        const utm_campaign = urlParams.get('utm_campaign') || '';

        let audience = 'diy'; // default

        // Simple detection logic
        if (referrer.includes('g2.com') || referrer.includes('capterra')) {
            audience = 'diy';
        }
        if (utm_source === 'linkedin' || referrer.includes('linkedin')) {
            audience = 'agency';
        }

        return audience;
    }

    function personalizeHero() {
        const audience = detectAudience();
        const headline = document.getElementById('hero-headline');
        const subheading = document.getElementById('hero-subheading');

        if (audience === 'agency') {
            headline.textContent = 'White-Label Lead Automation for Your Clients';
            subheading.textContent = 'Agencies reselling ProspectID + ProspectMax report 40% higher client retention and 30% more expansion revenue.';
        } else {
            // Default DIY
            headline.textContent = 'Stop Losing $50k/Month to Missed Calls';
            subheading.textContent = 'Businesses using ProspectMax recover an average of $47,000/month in lost revenue within 90 days.';
        }
    }

    // ============================================
    // ROI CALCULATOR
    // ============================================
    function calculateROI(event) {
        event.preventDefault();

        const industry = document.getElementById('industry').value;
        const leadsPerMonth = parseInt(document.getElementById('leads-per-month').value);
        const closeRate = parseInt(document.getElementById('close-rate').value) / 100;
        const dealValue = parseInt(document.getElementById('deal-value').value);

        // Calculate potential revenue
        const potentialRevenue = leadsPerMonth * closeRate * dealValue;

        // Assume 30% lost to missed calls/slow response
        const lostRevenue = potentialRevenue * 0.30;

        // ProspectMax recovers ~70% of lost revenue
        const recoveredRevenue = lostRevenue * 0.70;

        // Display results
        const result = document.getElementById('roi-result');
        document.getElementById('roi-amount').textContent = `$${Math.round(lostRevenue).toLocaleString()}`;
        document.getElementById('roi-recovery').textContent = `That's $${Math.round(recoveredRevenue).toLocaleString()}/month in recovered revenue.`;

        result.classList.add('show');
        result.scrollIntoView({ behavior: 'smooth' });
    }

    // ============================================
    // FAQ TOGGLE
    // ============================================
    function toggleFAQ(element) {
        const item = element.parentElement;
        item.classList.toggle('open');
    }

    // ============================================
    // DEMO BOOKING
    // ============================================
    function handleDemoBooking(event) {
        event.preventDefault();
        alert('Thank you! We'll send you a calendar link shortly.');
        // In production, this would submit to Salesforce/CRM
        document.getElementById('demo-form').style.display = 'none';
    }

    // ============================================
    // INITIALIZATION
    // ============================================
    document.addEventListener('DOMContentLoaded', function() {
        personalizeHero();
        
        // Add scroll animations
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animate-fade-in-up');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('section').forEach(el => {
            observer.observe(el);
        });
    });

    // ============================================
    // ANALYTICS (GA4 integration)
    // ============================================
    function trackEvent(eventName, eventData = {}) {
        if (window.gtag) {
            gtag('event', eventName, eventData);
        }
        console.log('Event tracked:', eventName, eventData);
    }

    // Track CTA clicks
    document.querySelectorAll('.btn').forEach(btn => {
        btn.addEventListener('click', function() {
            trackEvent('cta_click', {
                button_text: this.textContent,
                section: this.closest('section')?.id || 'unknown'
            });
        });
    });
</script>

</body>
